<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                   x:Class="Corvida.Views.Dialogs.PickerDialog"
                   Title="Move to Group"
                   Width="340" Height="260"
                   CanResize="False"
                   WindowStartupLocation="CenterOwner"
                   ShowInTaskbar="False">

    <DockPanel Margin="16" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0 10 0 0">
            <Button Content="Cancel" Click="Cancel_Click" Classes="Basic"/>
            <Button Content="OK" Click="Ok_Click" Classes="Flat"/>
        </StackPanel>

        <ListBox x:Name="OptionsList" DoubleTapped="OptionsList_DoubleTapped"/>
    </DockPanel>
</sukiUi:SukiWindow>
