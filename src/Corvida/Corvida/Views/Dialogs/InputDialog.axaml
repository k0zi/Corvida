<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                   x:Class="Corvida.Views.Dialogs.InputDialog"
                   Title="Input"
                   Width="360" Height="200"
                   CanResize="False"
                   WindowStartupLocation="CenterOwner"
                   ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="12" VerticalAlignment="Center">
        <TextBlock x:Name="PromptText" FontSize="14" TextWrapping="Wrap"/>
        <TextBox x:Name="InputBox" KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="Cancel_Click" Classes="Basic"/>
            <Button Content="OK" Click="Ok_Click" Classes="Flat"/>
        </StackPanel>
    </StackPanel>
</sukiUi:SukiWindow>
