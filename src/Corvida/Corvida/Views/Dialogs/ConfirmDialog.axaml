<sukiUi:SukiWindow xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:sukiUi="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                   x:Class="Corvida.Views.Dialogs.ConfirmDialog"
                   Title="Confirm"
                   Width="360" Height="180"
                   CanResize="False"
                   WindowStartupLocation="CenterOwner"
                   ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="16" VerticalAlignment="Center">
        <TextBlock x:Name="MessageText" FontSize="14" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="No" Click="No_Click" Classes="Basic"/>
            <Button Content="Yes" Click="Yes_Click" Classes="Flat"/>
        </StackPanel>
    </StackPanel>
</sukiUi:SukiWindow>
